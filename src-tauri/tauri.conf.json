{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DroidPrint",
  "version": "0.1.0",
  "identifier": "com.droidprint.app",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://127.0.0.1:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File src-tauri\\scripts\\prepare-backend-zip.ps1"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DroidPrint",
        "width": 1200,
        "height": 640,
        "resizable": true,
        "fullscreen": false,
        "url": "http://127.0.0.1:3000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/backend.zip"
    ]
  }
}
